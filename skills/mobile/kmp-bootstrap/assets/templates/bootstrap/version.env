# Source of truth for app versioning across Android and iOS.
# Android reads these directly in build.gradle.kts.
# iOS mirrors MARKETING_VERSION / CURRENT_PROJECT_VERSION from these via `make sync-version`.

VERSION_NAME=0.1.0
VERSION_CODE=1

# Optional: override the build number emitted to iOS.
# Defaults to VERSION_CODE when unset.
# BUILD_NUMBER=1
