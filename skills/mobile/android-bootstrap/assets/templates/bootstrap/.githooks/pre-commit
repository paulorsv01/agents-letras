#!/bin/sh
# Pre-commit: run ktlint on staged Kotlin files.
# Activate with: git config core.hooksPath .githooks
set -e

STAGED=$(git diff --cached --name-only --diff-filter=ACMR -- '*.kt' '*.kts' || true)
[ -z "$STAGED" ] && exit 0

if ! command -v ktlint >/dev/null 2>&1; then
  printf 'ktlint not installed — skipping pre-commit lint. brew install ktlint\n' >&2
  exit 0
fi

printf 'Running ktlint on staged Kotlin files...\n'
# shellcheck disable=SC2086  # intentional word-split on filenames (newline-separated)
echo "$STAGED" | xargs ktlint --format

# Re-stage files that ktlint reformatted.
echo "$STAGED" | xargs git add
