# Copy this file to ".env" (gitignored) and fill in your tokens.
#   cp .env.example .env

# REQUIRED for fetching (update.py, fetch_posts.py, discover_new.py).
# X Developer Console -> your App -> Keys and tokens -> "Bearer Token"
# (the long string starting with AAAA... — not the API Key/Secret).
X_BEARER_TOKEN=PASTE_YOUR_X_BEARER_TOKEN_HERE

# OPTIONAL — only for the auto-distiller (distill.py). You can also authenticate
# via `ant auth login` instead of setting a key here.
# ANTHROPIC_API_KEY=sk-ant-...
